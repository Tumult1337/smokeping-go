{
  "title": "gosmokeping",
  "uid": "gosmokeping",
  "tags": ["network", "smokeping", "latency"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "constant",
        "query": "smokeping_raw",
        "current": { "text": "smokeping_raw", "value": "smokeping_raw" },
        "hide": 0
      },
      {
        "name": "group",
        "label": "Group",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"group\")",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      },
      {
        "name": "target",
        "label": "Target",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"target\", predicate: (r) => contains(value: r.group, set: ${group:json}))",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Latency — $target (smoke band)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 },
      "repeat": "target",
      "repeatDirection": "v",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"probe_cycle\")\n  |> filter(fn: (r) => r.target == \"${target}\")\n  |> filter(fn: (r) => r._field == \"rtt_min\" or r._field == \"rtt_max\" or r._field == \"rtt_p5\" or r._field == \"rtt_p95\" or r._field == \"rtt_median\")\n  |> keep(columns: [\"_time\", \"_field\", \"_value\"])\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rtt_median" },
            "properties": [
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rtt_min" },
            "properties": [
              { "id": "custom.fillBelowTo", "value": "rtt_max" },
              { "id": "custom.fillOpacity", "value": 10 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rtt_p5" },
            "properties": [
              { "id": "custom.fillBelowTo", "value": "rtt_p95" },
              { "id": "custom.fillOpacity", "value": 25 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Loss % — $target",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 6 },
      "repeat": "target",
      "repeatDirection": "v",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"probe_cycle\" and r._field == \"loss_pct\")\n  |> filter(fn: (r) => r.target == \"${target}\")"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "bars", "fillOpacity": 60 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    }
  ],
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ]
}
