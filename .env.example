# gosmokeping auto-loads this file via godotenv at startup. Values here are
# visible to the ${NAME} expansion in config.json (see config.example.json).
# Real shell env always wins over .env, so local overrides still work.

# InfluxDB v2 token used by the writer/reader.
INFLUX_TOKEN=

# Shared secret for master/slave cluster endpoints. Must match on both sides.
CLUSTER_TOKEN=

# Webhook URL for the Discord action (remove if unused).
DISCORD_WEBHOOK_URL=
