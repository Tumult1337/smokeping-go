# gosmokeping auto-loads this file at startup (from the directory holding
# --config, then from cwd). Values here are visible to ${NAME} expansion in
# config.json. Real shell env always wins over .env, so local overrides work.

# --- InfluxDB (required for master / standalone) ---------------------------
# URL, org, and token for your InfluxDB v2 instance. The token needs write
# access to the smokeping_* buckets (or org-wide write).
INFLUX_URL=http://localhost:8086
INFLUX_ORG=smokeping
INFLUX_TOKEN=

# --- Cluster (only if running master/slave) --------------------------------
# Shared bearer token for the /api/v1/cluster/* endpoints. Must match on the
# master and every slave. Leave blank for standalone.
CLUSTER_TOKEN=

# --- Alert webhooks (optional) ---------------------------------------------
# Remove or comment out whichever channels you don't use.
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
